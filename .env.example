# ─── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=wain_db
MYSQL_USER=wain_user
MYSQL_PASSWORD=change_this_db_password

# ─── Backend ──────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_64_chars
RECAPTCHA_SECRET=your_recaptcha_secret_key
WA_LOG_LEVEL=info

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL API Backend Anda (Wajib untuk setup 2 domain. Contoh: https://api.setorwader.com/api)
VITE_API_URL=https://api.domain-anda.com/api

# Port to expose the frontend on the host (default: 80)
FRONTEND_PORT=80
