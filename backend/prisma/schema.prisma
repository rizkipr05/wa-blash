datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                Int              @id @default(autoincrement())
  username          String           @unique
  password          String
  balance           Decimal          @default(0.00) @db.Decimal(15, 2)
  bankName          String?
  accountNumber     String?
  accountHolder     String?
  referralCode      String           @unique
  referredBy        Int?
  rank              String           @default("BASIC")
  role              String           @default("USER") // USER, ADMIN
  isTelegramConnected Boolean        @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  devices           WhatsAppDevice[]
  withdrawals       Withdrawal[]
  transactions      Transaction[]
  referrals         User[]           @relation("UserReferrals")
  referrer          User?            @relation("UserReferrals", fields: [referredBy], references: [id])
}

model WhatsAppDevice {
  id          Int      @id @default(autoincrement())
  userId      Int
  phoneNumber String?
  status      String   @default("DISCONNECTED") // CONNECTED, DISCONNECTED
  sessionData String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model Withdrawal {
  id            Int      @id @default(autoincrement())
  userId        Int
  amount        Decimal  @db.Decimal(15, 2)
  bankDetails   Json
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Decimal  @db.Decimal(15, 2)
  type        String   // EARNING, WITHDRAWAL, COMMISSION
  description String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}
